{
  "name": "arm-js-library",
  "version": "2.6.2",
  "description": "API Resource Manager",
  "type": "module",
  "files": [
    "dist",
    "types",
    "DOCS.md"
  ],
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/arm-js-library.js",
      "types": "./types/index.d.ts"
    }
  },
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "build:jsdocs": "jsdoc2md --private src/lib/api-resource-manager.js > DOCS.md",
    "build:dts": "tsc dist/arm-js-library.js --declaration --allowJs --emitDeclarationOnly --outFile types/index.d.ts --lib esnext --module esnext --skipLibCheck",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest run --reporter=verbose --watch"
  },
  "keywords": [
    "uuid",
    "state-management",
    "mobx",
    "json-api",
    "lodash",
    "md5",
    "centralized-data",
    "javascript",
    "reactjs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaeljymsgutierrez/arm-js-library.git"
  },
  "author": "Michael Jyms Gutierrez",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "jsdoc-to-markdown": "^8.0.3",
    "jsdom": "^27.4.0",
    "miragejs": "^0.1.48",
    "typescript": "^5.5.4",
    "vite": "^7.3.1",
    "vite-plugin-eslint": "^1.8.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "lodash": "^4.17.21",
    "md5": "^2.3.0",
    "mobx": "^6.15.0",
    "qs": "^6.14.1",
    "uuid": "^13.0.0"
  }
}
